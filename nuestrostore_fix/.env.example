# Copia este archivo como .env y configura tus valores

# SEGURIDAD — Genera una clave única en producción:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esto-en-produccion-XXXXXXXXXXXXXXXX

# DEBUG: usa True solo en desarrollo local, False en producción
DEBUG=False

# Base de datos (opcional — si no se define, usa SQLite local)
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nuestrostore

# Hosts permitidos en producción (separados por coma)
# ALLOWED_HOSTS=tudominio.com,www.tudominio.com
